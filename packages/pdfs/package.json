{
  "name": "@workspace/pdfs",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./invoices": "./dist/invoices/index.js",
    "./server": "./dist/server/index.js",
    "./shared/*": "./dist/shared/*.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/iw-logo.jpg dist/iw-logo.jpg",
    "lint": "eslint src",
    "test": "pnpm exec tsx --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.3.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
