{
  "name": "@workspace/emails",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp src/iw-logo.jpg dist/iw-logo.jpg",
    "lint": "eslint src",
    "render": "node --import tsx scripts/render.ts",
    "test": "pnpm exec tsx --test \"src/**/*.test.ts\" \"src/**/*.test.tsx\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@react-email/components": "^0.5.7",
    "@react-email/render": "^1.4.0",
    "@react-email/tailwind": "^1.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
