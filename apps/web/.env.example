# Frontend-safe only. These values are exposed to the browser bundle.
#
# Local dev: leave VITE_API_BASE_URL unset to use the Vite `/api` proxy (same-origin
# cookies; reliable on Mobile Safari / LAN). Or set a full URL to call the API directly.
# VITE_API_BASE_URL=
#
# If the API listens somewhere other than 127.0.0.1:3000, point the dev proxy at it (not
# exposed to the client bundle; use this file in apps/web):
# DEV_API_PROXY_TARGET=http://127.0.0.1:3000
