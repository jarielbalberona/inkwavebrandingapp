NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/ink_wave_branding_app
# Optional: use these instead of DATABASE_URL when the DB password contains @, #, etc. (all four required).
# DATABASE_HOST=localhost
# DATABASE_PORT=5433
# DATABASE_USER=postgres
# DATABASE_PASSWORD=postgres
# DATABASE_NAME=ink_wave_branding_app
DATABASE_SSL_MODE=disable
AUTH_SESSION_SECRET=replace-with-at-least-32-random-characters
AUTH_SESSION_TTL_SECONDS=28800
WEB_ORIGIN=http://localhost:5173
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0
OPENAI_API_KEY=
STORAGE_PROVIDER=none
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=
R2_USE_PUBLIC_CDN=true
UPLOAD_MAX_FILE_BYTES=5242880
UPLOAD_MAX_REQUEST_BYTES=52428800
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-random-password
ADMIN_DISPLAY_NAME=Ink Wave Admin
