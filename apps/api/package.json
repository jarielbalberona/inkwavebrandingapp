{
  "name": "@workspace/api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:check": "node --import tsx src/db/check.ts",
    "migrate:create": "node-pg-migrate create -m ./migrations",
    "migrate:up": "node-pg-migrate -m ./migrations up",
    "migrate:down": "node-pg-migrate -m ./migrations down"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "node-pg-migrate": "^8.0.4",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
