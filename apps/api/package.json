{
  "name": "@workspace/api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "node --import tsx src/server.ts",
    "lint": "eslint .",
    "test": "node --import tsx --test \"src/**/*.test.ts\"",
    "test:integration": "docker compose -f ../../docker-compose.dev.yml up -d postgres && vitest run --config vitest.integration.config.ts",
    "e2e:server": "docker compose -f ../../docker-compose.dev.yml up -d postgres && node --import tsx src/test/e2e/server.ts",
    "typecheck": "tsc --noEmit",
    "db:check": "node --import tsx src/db/check.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:deploy": "node --import tsx src/db/migrate-deploy.ts",
    "db:studio": "drizzle-kit studio",
    "db:drizzle-check": "drizzle-kit check",
    "seed:admin": "node --import tsx src/modules/users/seed-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.937.0",
    "@sentry/node": "^10.49.0",
    "@workspace/pdfs": "workspace:*",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "pg-connection-string": "2.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.2",
    "globals": "^17.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.1.5"
  }
}
