{
  "name": "ink-wave-branding-app",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "deploy:check": "pnpm --filter @workspace/api typecheck && pnpm --filter @workspace/api build && pnpm --filter @workspace/api db:drizzle-check && pnpm --filter web typecheck && pnpm --filter web build",
    "lint": "turbo lint",
    "format": "turbo format",
    "test": "turbo test",
    "test:integration": "pnpm --filter @workspace/api test:integration",
    "test:e2e": "VITE_API_BASE_URL=http://127.0.0.1:3100 pnpm build && playwright test",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.17",
    "typescript": "5.9.3"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  }
}
